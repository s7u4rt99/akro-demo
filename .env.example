# Required: OpenAI API key for all agents (Planner, Researcher, Synthesizer, Critic)
# Get it from: https://platform.openai.com/api-keys
# Create an account or sign in, then "Create new secret key"
OPENAI_API_KEY=sk-your-key-here

# Required: Tavily API key for web search (1,000 free credits/month)
# Get it from: https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# Optional: Model to use (default: gpt-4o-mini for cost/speed; use gpt-4o for higher quality)
OPENAI_MODEL=gpt-4o-mini
